NODE_ENV=development

# Server Configuration
PORT=5000

# Database Configuration
# Development: MongoDB locally
MONGO_URI=mongodb://localhost:27017/skillswap-connect
# Production: Use MongoDB Atlas
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/skillswap-connect

# JWT Configuration (Change in production!)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_jwt_key_change_in_production_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# API Configuration
API_BASE_URL=http://localhost:5000/api
# Production: Use actual domain
# API_BASE_URL=https://your-render-backend.onrender.com/api

# CORS Configuration (Update for production)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:3000,exp://127.0.0.1:8081
# Production: Add your Vercel domain
# CORS_ORIGINS=https://your-vercel-app.vercel.app,https://your-domain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Cloudinary Configuration (Optional - for media uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# OpenAI Configuration (Optional - for AI chat assistant)
OPENAI_API_KEY=your_openai_api_key_here

# Logging
LOG_LEVEL=debug
